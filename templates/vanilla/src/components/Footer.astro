<footer class="bg-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="md:col-span-1">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-gradient-to-r from-blue-900 to-blue-600 rounded-full flex items-center justify-center mr-3">
            <!-- Replace with your logo/icon -->
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
              <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-xl font-bold">XXX_BRAND_NAME</span>
        </div>
        <p class="text-gray-400 mb-6">
          XXX_TAGLINE
        </p>
        <div class="flex space-x-4">
          <!-- Social Media Links - Update with your actual profiles -->
          <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
