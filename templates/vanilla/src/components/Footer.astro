            </svg>
          </a>
          <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="Twitter">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Main Content Links -->
      <div>
        <h3 class="text-lg font-semibold mb-4">XXX_SECTION_1_TITLE</h3>
        <ul class="space-y-2">
          <!-- STAGE 1: Only link to pages that exist -->
          <!-- Example Stage 1 links - replace with your actual pages -->
          <li><a href="/XXX_PAGE_1" class="text-gray-400 hover:text-white transition-colors">XXX_PAGE_1_TITLE</a></li>
          <li><a href="/XXX_PAGE_2" class="text-gray-400 hover:text-white transition-colors">XXX_PAGE_2_TITLE</a></li>
          <li><a href="/XXX_PAGE_3" class="text-gray-400 hover:text-white transition-colors">XXX_PAGE_3_TITLE</a></li>
          <li class="text-gray-500 text-sm pt-2">More coming soon...</li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Resources</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">About</a></li>
          <!-- Use anchor link for contact if no separate page -->
          <li><a href="/#contact" class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
          <li><a href="/sitemap" class="text-gray-400 hover:text-white transition-colors">Sitemap</a></li>
        </ul>
      </div>

      <!-- Legal - ALWAYS CREATE THESE PAGES -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy-policy" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="/disclaimer" class="text-gray-400 hover:text-white transition-colors">Disclaimer</a></li>
        </ul>
        
        <div class="mt-6">
          <h4 class="text-sm font-semibold mb-2">Stay Updated</h4>
          <p class="text-gray-400 text-sm mb-3">Get the latest updates</p>
          <div class="flex">
            <input type="email" placeholder="Enter your email" class="flex-1 px-3 py-2 bg-gray-800 text-white rounded-l-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button class="bg-gradient-to-r from-blue-600 to-blue-500 px-4 py-2 rounded-r-md text-sm font-medium hover:from-blue-700 hover:to-blue-600 transition-colors">
              Subscribe
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-300 text-sm">
        &copy; 2025 XXX_BRAND_NAME. All rights reserved.
      </p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/privacy-policy" class="text-gray-400 hover:text-white text-sm transition-colors">Privacy</a>
        <a href="/terms-of-service" class="text-gray-400 hover:text-white text-sm transition-colors">Terms</a>
        <a href="/sitemap" class="text-gray-400 hover:text-white text-sm transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

